<Page x:Class="Exam.Pages.Orders"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Exam.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Orders">

    <Grid>
        <Grid Height="50" Background="#7FFF00" VerticalAlignment="Top">
            <Image Source="/Images/Icon.png" HorizontalAlignment="Left" Margin="5"/>
            <Label x:Name="UserName"  FontSize="14" HorizontalAlignment="Right" Margin="0,0,230,0" VerticalAlignment="Center"/>
            <Button Click="OpenProductsPage" Content="продукты" FontSize="14" HorizontalAlignment="Right" Width="100" Height="30" Background="#00FA9A" Margin="10"/>
            <Button Click="OpenAddOrderPage" x:Name="OpenAddOrderPageBtn" Content="создать заказ" FontSize="14" HorizontalAlignment="Right" Width="100" Height="30" Background="#00FA9A" Margin="0,10,120,10"/>
        </Grid>
        <ScrollViewer Background="White" Margin="0,50,0,0">
            <StackPanel x:Name="OrdersList"/>
        </ScrollViewer>
    </Grid>
</Page>

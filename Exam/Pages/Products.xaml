<Page x:Class="Exam.Pages.Products"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Exam.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Products">

    <Grid>
        <Grid Height="100" Background="#7FFF00" VerticalAlignment="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Image Source="/Images/Icon.png" HorizontalAlignment="Left" Margin="5"/>
            <Label x:Name="UserName"  FontSize="14" HorizontalAlignment="Right" Margin="0,0,390,0" VerticalAlignment="Center"/>
            <Button Click="OpenAuthorizationPage" Content="выйти" FontSize="14" HorizontalAlignment="Right" Width="100" Height="30" Background="#00FA9A" Margin="10"/>
            <Button Click="OpenOrdersPage" x:Name="OpenOrdersPageBtn"  Visibility="Hidden" Content="заказы" FontSize="14" HorizontalAlignment="Right" Width="100" Height="30" Background="#00FA9A" Margin="0,10,120,10"/>
            <Button Click="OpenAddProductPage" x:Name="OpenAddProductPageBtn" Visibility="Hidden" Content="создать продукт" FontSize="14" HorizontalAlignment="Right" Width="150" Height="30" Background="#00FA9A" Margin="0,10,230,10"/>
            <StackPanel Orientation="Horizontal" Grid.Row="1">
                <Label Content="Поиск" VerticalAlignment="Center"/>
                <TextBox x:Name="Search" TextChanged="SortProducts" Height="25" Width="200"/>
                <Label Content="Производитель" VerticalAlignment="Center"/>
                <ComboBox x:Name="Manufacturers" SelectionChanged="SortProducts" DisplayMemberPath="Name" SelectedValuePath="Id" Height="25" Width="150"/>
                <Label Content="Сортировка" VerticalAlignment="Center"/>
                <ComboBox x:Name="OrderBy" SelectionChanged="SortProducts" Height="25" Width="150">
                    <ComboBoxItem Content="По умолчанию"/>
                    <ComboBoxItem Content="По возрастанию кол-ва"/>
                    <ComboBoxItem Content="По убыванию кол-ва" />
                </ComboBox>
            </StackPanel>

        </Grid>
        <ScrollViewer Background="White" Margin="0,100,0,0">
            <StackPanel x:Name="ProductsList"/>
        </ScrollViewer>
    </Grid>
</Page>

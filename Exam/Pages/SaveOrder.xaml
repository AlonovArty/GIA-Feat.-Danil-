<Page x:Class="Exam.Pages.SaveOrder"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Exam.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SaveOrder">

    <Grid>
        <Grid Height="50" Background="#7FFF00" VerticalAlignment="Top">
            <Label Content="Сохранить заказ" FontSize="20" VerticalAlignment="Center" Margin="50,0,0,0"/>
            <Image Source="/Images/Icon.png" HorizontalAlignment="Left" Margin="5"/>
            <Label x:Name="UserName"  FontSize="14" HorizontalAlignment="Right" Margin="0,0,120,0" VerticalAlignment="Center"/>
            <Button Click="AddProduct" Content="Добавить продукт" FontSize="14" HorizontalAlignment="Right" Width="150" Height="30" Background="#00FA9A" Margin="0,0,120,0"/>
            <Button Click="OpenProductsPage" Content="Назад" FontSize="14" HorizontalAlignment="Right" Width="100" Height="30" Background="#00FA9A" Margin="10"/>
        </Grid>
        <ScrollViewer Margin="0,50,0,50">
            <StackPanel Margin="10,0,10,0">
                <Label Content="Статус"/>
                <ComboBox x:Name="Statuses" DisplayMemberPath="Name" SelectedValuePath="Id" Height="25" />
                <Label Content="Пункт выдачи"/>
                <ComboBox x:Name="PickupPoints" DisplayMemberPath="Address" SelectedValuePath="Id" Height="25"/>
                <Label Content="Клиент"/>
                <ComboBox x:Name="Clients" DisplayMemberPath="FIO" SelectedValuePath="Id" Height="25"/>
                <Label Content="Дата заказа"/>
                <DatePicker x:Name="OrderDate" Height="25"/>
                <Label Content="Дата доставки"/>
                <DatePicker x:Name="DeliveryDate" Height="25"/>
                <StackPanel x:Name="OrderProducts"/>
            </StackPanel>
        </ScrollViewer>
        <Button Click="Save" Content="Сохранить" HorizontalAlignment="Right" Margin="0,0,10,10" VerticalAlignment="Bottom" Width="100" Height="30" Background="#00FA9A"/>
    </Grid>
</Page>

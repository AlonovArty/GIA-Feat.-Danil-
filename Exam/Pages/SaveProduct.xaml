<Page x:Class="Exam.Pages.SaveProduct"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Exam.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="1000" d:DesignWidth="800"
      Title="SaveProduct">
    <Grid>
            <Grid Height="50" Background="#7FFF00" VerticalAlignment="Top">
                <Label Content="Сохранить продукт" FontSize="20" VerticalAlignment="Center" Margin="50,0,0,0"/>
                <Image Source="/Images/Icon.png" HorizontalAlignment="Left" Margin="5"/>
                <Label x:Name="UserName"  FontSize="14" HorizontalAlignment="Right" Margin="0,0,120,0" VerticalAlignment="Center"/>
                <Button Click="OpenProductsPage" Content="Назад" FontSize="14" HorizontalAlignment="Right" Width="100" Height="30" Background="#00FA9A" Margin="10"/>
            </Grid>
            <ScrollViewer Margin="0,50,0,50">
                <StackPanel Margin="10,0,10,0">
                    <Image x:Name="Image" Source="/Images/picture.png" Height="150" Width="100"/>
                    <Button Click="SelectImage" Content="Выбрать изображение" Width="200" Height="25"/>
                    <Label Content="Артикул"/>
                    <TextBox x:Name="Article" Height="25"/>
                    <Label Content="Название"/>
                    <TextBox x:Name="Name" Height="25"/>
                    <Label Content="Описание"/>
                    <TextBox x:Name="Description" Height="75" TextWrapping="Wrap"/>
                    <Label Content="Цена"/>
                    <TextBox x:Name="Priсe" Height="25"/>
                    <Label Content="Количество"/>
                    <TextBox x:Name="Quantity" Height="25"/>
                    <Label Content="Скидка"/>
                    <TextBox x:Name="Discount" Height="25"/>
                    <Label Content="Единица измереня"/>
                    <ComboBox x:Name="Units" DisplayMemberPath="Name" SelectedValuePath="Id" Height="25"/>
                    <Label Content="Категория"/>
                    <ComboBox x:Name="Categories" DisplayMemberPath="Name" SelectedValuePath="Id" Height="25"/>
                    <Label Content="Производитель"/>
                    <ComboBox x:Name="Manufacturers" DisplayMemberPath="Name" SelectedValuePath="Id" Height="25"/>
                    <Label Content="Поставщик"/>
                    <ComboBox x:Name="Providers" DisplayMemberPath="Name" SelectedValuePath="Id" Height="25"/>
                </StackPanel>
            </ScrollViewer>
            <Button Click="Save" Content="Сохранить" HorizontalAlignment="Right" Margin="0,0,10,10" VerticalAlignment="Bottom" Width="100" Height="30" Background="#00FA9A"/>
    </Grid>
</Page>

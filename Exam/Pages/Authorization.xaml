<Page x:Class="Exam.Pages.Authorization"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Exam.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Authorization">

    <Grid Background="White">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="200">
            <Image Source="/Images/Icon.JPG" Height="100"/>
            <Label Content="вход в аккаунт" HorizontalAlignment="Center" FontWeight="Bold" FontSize="16"/>
            <Label Content="логин" FontSize="14" HorizontalAlignment="Center"/>
            <TextBox x:Name="Login" Height="30"/>
            <Label Content="пароль" FontSize="14" HorizontalAlignment="Center"/>
            <TextBox x:Name="Password" Height="30"/>
            <Button Content="войти" Click="OpenProductsPage" FontSize="14" Height="30" Margin="0,20,0,20" Background="#00FA9A"/>
        </StackPanel>
    </Grid>
</Page>

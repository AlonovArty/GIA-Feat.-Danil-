<UserControl x:Class="Exam.Elements.Product"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Exam.Elements"
             mc:Ignorable="d">
    <Grid x:Name="BaseGrid" Height="220" MinWidth="600">
        <Image x:Name="Image" Margin="10" Source="/Images/picture.png" Width="180" HorizontalAlignment="Left"/>
        <StackPanel Margin="200,10,100,10" VerticalAlignment="Center"  HorizontalAlignment="Left">
            <Label x:Name="CategoryAndName" Content="Категория товара | Наименование товара" FontWeight="Bold" FontSize="14"/>
            <Label x:Name="Description" Content="Описание:" />
            <Label x:Name="Manufacturer" Content="Производитель:"/>
            <Label x:Name="Provider" Content="Поставщик:"/>
            <TextBlock x:Name="Price" Text="Цена:" Margin="5"/>
            <Label x:Name="Unit" Content="Еденица измерения:"/>
            <Label x:Name="Quantity" Content="Количество на складе:"/>
        </StackPanel>
        <Grid Margin="10">
            <Label x:Name="Discount" Content="Скидка: 0%" FontSize="14" HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>
        <Button Click="Delete" x:Name="DeleteBtn" Content="Удалить" Visibility="Hidden" Height="25" Width="100" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="10,10,120,10"/>
        <Button Click="Edit" x:Name="EditBtn" Content="Изменить" Visibility="Hidden" Height="25" Width="100" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="10"/>

    </Grid>
</UserControl>
